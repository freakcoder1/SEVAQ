{
  "$schema": "https://railway.com/railway.schema.json",
  "root": ".",
  "build": {
    "builder": "NIXPACKS",
    "nodeVersion": "22",
    "buildCommand": "cd flutter-nest-househelp-master && npm run build"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyLimit": 5,
    "sleepApplication": false,
    "startCommand": "cd flutter-nest-househelp-master && node dist/main"
  },
  "env": {
    "SYNCHRONIZE": "true",
    "NODE_ENV": "production",
    "LOG_LEVEL": "info"
  }
}