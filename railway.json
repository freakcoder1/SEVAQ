{
  "$schema": "https://railway.com/railway.schema.json",
  "name": "SEVAQ",
  "watchPatterns": [
    "flutter-nest-househelp-master/**/*"
  ],
  "build": {
    "builder": "DOCKER"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyLimit": 5,
    "sleepApplication": false
  },
  "env": {
    "SYNCHRONIZE": "false",
    "NODE_ENV": "production",
    "LOG_LEVEL": "info",
    "DB_SSL_REQUIRE": "true"
  }
}
