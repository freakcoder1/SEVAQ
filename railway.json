{
  "$schema": "https://railway.com/railway.schema.json",
  "name": "SEVAQ",
  "watchPatterns": [
    "flutter-nest-househelp-master/**/*"
  ],
  "build": {
    "builder": "NIXPACKS",
    "nodeVersion": "22",
    "buildCommand": "npm install --legacy-peer-deps && npm run build && npm run seed:railway",
    "workingDirectory": "flutter-nest-househelp-master"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyLimit": 5,
    "sleepApplication": false,
    "workingDirectory": "flutter-nest-househelp-master",
    "startCommand": "node start.js"
  },
  "env": {
    "SYNCHRONIZE": "false",
    "NODE_ENV": "production",
    "LOG_LEVEL": "info",
    "DB_SSL_REQUIRE": "true"
  }
}
