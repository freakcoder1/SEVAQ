{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nodeVersion": "22",
    "buildCommand": "npm ci && npm run build",
    "installCommand": "npm ci"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyLimit": 5,
    "sleepApplication": false
  }
}
